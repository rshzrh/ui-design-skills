# ui-android slop-blocking detekt rules. Merge into config/detekt/detekt.yml.
# Active bans: {{ACTIVE_BANS}}
#
# Apply via app/build.gradle.kts:
#
# plugins {
#   id("io.gitlab.arturbosch.detekt") version "1.23.6"
# }
# detekt {
#   config.setFrom(files("$rootDir/config/detekt/detekt.yml"))
#   buildUponDefaultConfig = true
#   allRules = false
# }
# tasks.named("check") { dependsOn("detekt") }

style:
  ForbiddenComment:
    active: true
    # [Ban 14] Buzzwords in comments
    comments:
      - reason: "Banned buzzword. Replace with a concrete property from your anchor recipe."
        value: "(?i)\\b(clean|modern|professional|sleek|premium|beautiful|elegant)\\b"

  MagicNumber:
    active: true
    # Encourage spacing/dp/sp values to come from theme tokens.
    excludes:
      - '**/ui/theme/**'
      - '**/test/**'
      - '**/androidTest/**'
    ignoreNumbers: ['-1', '0', '1', '2']

  ForbiddenMethodCall:
    active: true
    methods:
      # [Ban 5] Glassmorphism — Modifier.blur on cards
      - reason: "Banned: Modifier.blur() on regular surfaces. Allowed only on bottom-sheet scrims if anchor explicitly permits."
        value: "androidx.compose.ui.draw.blur"

